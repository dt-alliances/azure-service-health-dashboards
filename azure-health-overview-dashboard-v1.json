    "21": {
      "title": "Combined Health Timeline",
      "type": "data",
      "query": "fetch logs\n| filter log.source == \"ServiceHealth\" or log.source == \"ResourceHealth\" or log.source == \"Recommendation\" or log.source == \"Security\"\n| summarize count = count(), by: { timeframe = bin(timestamp, 1h), source = log.source }",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "leftYAxisSettings": { "label": "Count" },
          "fieldMapping": { "leftAxisValues": ["count"], "timestamp": "timeframe" },
          "gapPolicy": "connect",
          "categoryOverrides": {
            "ServiceHealth": { "color": "#dc172a" },
            "ResourceHealth": { "color": "#f5d30a" },
            "Recommendation": { "color": "#1496ff" },
            "Security": { "color": "#7c38a1" }
          }
        }
      },
      "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 100, "defaultSamplingRatio": 10, "enableSampling": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "22": {
